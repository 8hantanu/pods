# pod-dev.env - Configuration for pod-dev
# Copy this file to .env and customize

# Git config
GIT_USER_NAME="Shantanu Mishra"
GIT_USER_EMAIL="git@8hantanu.net"

# SSH key settings (key generated if doesn't exist)
SSH_KEY_PATH="$HOME/.ssh/pod-dev-github"
SSH_KEY_COMMENT="pod-dev"

# Local project folder to mount into the container
LOCAL_PROJ_PATH="$HOME/Projects"

# Tool selection (true/false)
INSTALL_RUST=true
INSTALL_NODE=true
INSTALL_PYTHON=true
INSTALL_OPENCODE=true
INSTALL_NVIM=true

# Repos to clone during build (leave empty to skip)
DOTS_REPO="git@github.com:8hantanu/dots.git"
PLUG_REPO="git@github.com:8hantanu/plug.git"
WIKI_REPO="git@github.com:8hantanu/wiki.git"
