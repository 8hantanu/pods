# Use a slim Debian base for a stable day-to-day development pod
FROM debian:bookworm-slim

ARG USER_NAME=user
RUN useradd -ms /bin/bash $USER_NAME

ARG HOME_DIR="/home/${USER_NAME}"
ARG GIT_USER_NAME="Pod User"
ARG GIT_USER_EMAIL="pod-user@example.com"
ARG INSTALL_RUST="true"
ARG INSTALL_NODE="true"
ARG INSTALL_PYTHON="true"
ARG INSTALL_OPENCODE="true"
ARG INSTALL_NVIM="true"
ARG DOTS_REPO=""
ARG PLUG_REPO=""
ARG WIKI_REPO=""
ENV PLUG_PATH="/home/${USER_NAME}/ship/control/plug"
ENV PATH="${PLUG_PATH}:${PATH}"

RUN set -eu; \
    packages='autoconf automake build-essential ca-certificates cmake curl gettext git libavif-bin libtool libtool-bin openssh-client pkg-config ripgrep stow tmux tree unzip'; \
    if [ "${INSTALL_RUST}" = "true" ]; then packages="${packages} cargo rustc"; fi; \
    if [ "${INSTALL_NODE}" = "true" ] || [ "${INSTALL_OPENCODE}" = "true" ]; then packages="${packages} nodejs npm"; fi; \
    if [ "${INSTALL_PYTHON}" = "true" ]; then packages="${packages} python3 python3-pip python3-venv"; fi; \
    apt-get update && apt-get install -y --no-install-recommends ${packages} && rm -rf /var/lib/apt/lists/*

RUN if [ "${INSTALL_NVIM}" = "true" ]; then \
        set -eu; \
        arch="$(dpkg --print-architecture)"; \
        case "$arch" in \
            amd64) nvim_arch="x86_64" ;; \
            arm64) nvim_arch="arm64" ;; \
            *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
        esac; \
        curl -fsSL "https://github.com/neovim/neovim/releases/download/stable/nvim-linux-${nvim_arch}.tar.gz" -o /tmp/nvim.tar.gz; \
        rm -rf /opt/nvim; \
        tar -C /opt -xzf /tmp/nvim.tar.gz; \
        ln -sf "/opt/nvim-linux-${nvim_arch}/bin/nvim" /usr/local/bin/nvim; \
        rm -f /tmp/nvim.tar.gz; \
    fi

WORKDIR $HOME_DIR

RUN mkdir -p $HOME_DIR/proj $HOME_DIR/wiki $HOME_DIR/ship/reqs $HOME_DIR/ship/control $HOME_DIR/.ssh $HOME_DIR/.config/nvim $HOME_DIR/.local/share/nvim/site/autoload && \
    chown -R $USER_NAME:$USER_NAME $HOME_DIR && \
    chmod 700 $HOME_DIR/.ssh && \
    ssh-keyscan github.com > $HOME_DIR/.ssh/known_hosts && \
    chmod 600 $HOME_DIR/.ssh/known_hosts

RUN if [ "${INSTALL_RUST}" = "true" ]; then \
        curl -L https://github.com/rust-analyzer/rust-analyzer/releases/latest/download/rust-analyzer-linux -o /usr/local/bin/rust-analyzer && chmod +x /usr/local/bin/rust-analyzer; \
    fi

RUN if [ "${INSTALL_PYTHON}" = "true" ]; then pip3 install --break-system-packages pynvim; fi

RUN if [ "${INSTALL_OPENCODE}" = "true" ]; then npm install -g opencode-ai; fi

RUN --mount=type=secret,id=pod_dev_github_key,target=/run/secrets/pod_dev_github_key \
    set -eu; \
    cp /run/secrets/pod_dev_github_key /tmp/ssh_key && chmod 600 /tmp/ssh_key; \
    export GIT_SSH_COMMAND="ssh -i /tmp/ssh_key -o IdentitiesOnly=yes -o StrictHostKeyChecking=no -o UserKnownHostsFile=${HOME_DIR}/.ssh/known_hosts"; \
    if [ -n "${WIKI_REPO}" ]; then git clone --quiet "${WIKI_REPO}" "$HOME_DIR/wiki"; fi && \
    if [ -n "${PLUG_REPO}" ]; then git clone --quiet "${PLUG_REPO}" "$HOME_DIR/ship/control/plug"; fi && \
    if [ -n "${DOTS_REPO}" ]; then \
        git clone --quiet "${DOTS_REPO}" "$HOME_DIR/ship/control/dots" && \
        cd "$HOME_DIR/ship/control/dots" && stow --target="$HOME_DIR" . && \
        printf 'vim.cmd([[set runtimepath^=~/.vim runtimepath+=~/.vim/after\nlet &packpath = &runtimepath\nsource ~/.vimrc]])' > "$HOME_DIR/.config/nvim/init.lua"; \
    fi && \
    chown -R "${USER_NAME}:${USER_NAME}" "${HOME_DIR}"

USER $USER_NAME

RUN git config --global user.name "${GIT_USER_NAME}" && \
    git config --global user.email "${GIT_USER_EMAIL}" && \
    echo "export PS1='\\n\\A $ '" >> $HOME_DIR/.bashrc && \
    echo "export PLUG_PATH='${PLUG_PATH}'" >> $HOME_DIR/.bashrc && \
    echo 'export PATH="$PLUG_PATH:$PATH"' >> $HOME_DIR/.bashrc

CMD ["/bin/bash"]
